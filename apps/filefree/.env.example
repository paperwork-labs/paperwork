# FileFree Frontend — Environment Variables
# Copy secrets to .env.local (gitignored): cp .env.example .env.local
# See docs/CREDENTIALS.md for full credential registry

# === API ===
NEXT_PUBLIC_API_URL=http://localhost:8001

# === Clerk Auth (REQUIRED — must be set in Vercel for all environments) ===
# Secret key goes in .env.local only (never commit):
#   CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Route paths — tell Clerk's middleware to use embedded pages instead of hosted portal:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/file
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/file

# === Analytics (secrets — put in .env.local) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# === OAuth (secrets — put in .env.local) ===
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=

# === AI Model Overrides (optional — defaults are production-ready) ===
ADVISORY_MODEL=gpt-4o

# === Ops Dashboard (server-side secrets — put in .env.local) ===
N8N_API_KEY=
N8N_HOST=https://n8n.paperworklabs.com
GITHUB_TOKEN=
