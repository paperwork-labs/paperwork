# FileFree Frontend — Environment Variables
# Copy secrets to .env.local (gitignored): cp .env.example .env.local
# See docs/CREDENTIALS.md for full credential registry

# === API ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Analytics (secrets — put in .env.local) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# === OAuth (secrets — put in .env.local) ===
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=

# === AI Model Overrides (optional — defaults are production-ready) ===
ADVISORY_MODEL=gpt-4o

# === Ops Dashboard (server-side secrets — put in .env.local) ===
N8N_API_KEY=
N8N_HOST=https://n8n.paperworklabs.com
GITHUB_TOKEN=
