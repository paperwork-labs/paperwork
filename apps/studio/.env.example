# Studio Command Center — Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard for production.

# === Admin Auth (required for /admin routes) ===
ADMIN_EMAILS=sankalp@paperworklabs.com
ADMIN_ACCESS_PASSWORD=          # Set in Vercel (Production only)

# === n8n API (powers Agent Monitor, Infrastructure Health, Ops Dashboard) ===
N8N_API_URL=https://n8n.paperworklabs.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=        # Same as N8N_PASSWORD on Hetzner

# === GitHub (powers PR list on admin overview) ===
GITHUB_TOKEN=                   # Fine-grained PAT with repo:read scope

# === PostHog (powers Analytics page) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_DASHBOARD_URL=

# === Optional service checks (Infrastructure Health page) ===
# RENDER_API_KEY=
# VERCEL_TOKEN=
# NEON_API_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# POSTIZ_URL=https://social.paperworklabs.com
