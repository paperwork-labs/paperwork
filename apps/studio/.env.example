# Studio Command Center — Environment Variables
# Copy to .env.local for local dev, or set in Vercel dashboard for production.
# Fastest setup: make env-pull  (pulls all Vercel production vars to .env.local)

# === Admin Auth (required for /admin routes) ===
ADMIN_EMAILS=sankalp@paperworklabs.com
ADMIN_ACCESS_PASSWORD=          # Set in Vercel (Production only; dev bypasses auth)

# === n8n API (powers Agent Monitor, Infrastructure Health, Ops Dashboard) ===
N8N_API_URL=https://n8n.paperworklabs.com
N8N_API_KEY=                    # JWT from n8n user management (REST API auth)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=        # Same as N8N_PASSWORD on Hetzner

# === Brain API (powers /admin/agents Brain Persona registry + Ask Brain) ===
BRAIN_API_URL=https://brain.paperworklabs.com
BRAIN_API_SECRET=               # Same X-Brain-Secret value Brain expects on /admin/*

# === GitHub (powers PR list on admin overview) ===
GITHUB_TOKEN=                   # Fine-grained PAT with repo:read scope

# === Slack (powers Ops page connectivity test) ===
SLACK_BOT_TOKEN=                # Bot User OAuth Token from api.slack.com

# === Postiz (Infrastructure Health) ===
POSTIZ_URL=https://social.paperworklabs.com

# === PostHog (powers Analytics page — optional) ===
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# POSTHOG_DASHBOARD_URL=

# === Secrets Vault (powers /admin/secrets and /api/secrets/* API) ===
DATABASE_URL=                  # Neon connection string (postgresql://...)
SECRETS_ENCRYPTION_KEY=        # 32-byte base64 key: openssl rand -base64 32
SECRETS_API_KEY=               # Bearer token for machine access (n8n, scripts)

# === Optional service checks (Infrastructure Health page) ===
# RENDER_API_KEY=                # Lists every Render service + deploy state (GET /v1/services)
# VERCEL_API_TOKEN=              # Not VERCEL_TOKEN (reserved by Vercel build system)
# VERCEL_TEAM_ID=                # Team scope for Vercel API (same as Vercel dashboard team)
# VERCEL_TEAM_SLUG=paperwork-labs # Used in Vercel dashboard links (slug, not UUID)
# STUDIO_E2E_FIXTURE=            # Set to 1 only for Playwright e2e (mock platform rows). Never in prod.
# NEON_API_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
