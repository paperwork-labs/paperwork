{
  "name": "paperwork",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "postinstall": "node scripts/postinstall-check.mjs",
    "vercel:link": "bash scripts/vercel-link-all.sh",
    "vercel:link:check": "bash scripts/vercel-link-all.sh --check",
    "vercel:envs": "node scripts/vercel-list-all-envs.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "dev:filefree": "turbo run dev --filter=@paperwork-labs/filefree",
    "dev:studio": "turbo run dev --filter=@paperwork-labs/studio",
    "dev:launchfree": "turbo run dev --filter=@paperwork-labs/launchfree",
    "dev:trinkets": "turbo run dev --filter=@paperwork-labs/trinkets",
    "dev:distill": "turbo run dev --filter=@paperwork-labs/distill",
    "dev:accounts": "turbo run dev --filter=@paperwork-labs/accounts",
    "dev:axiomfolio": "turbo run dev --filter=@paperwork-labs/axiomfolio",
    "build:filefree": "turbo run build --filter=@paperwork-labs/filefree",
    "build:launchfree": "turbo run build --filter=@paperwork-labs/launchfree",
    "build:studio": "turbo run build --filter=@paperwork-labs/studio",
    "build:trinkets": "turbo run build --filter=@paperwork-labs/trinkets",
    "build:distill": "turbo run build --filter=@paperwork-labs/distill",
    "build:accounts": "turbo run build --filter=@paperwork-labs/accounts",
    "build:axiomfolio": "turbo run build --filter=@paperwork-labs/axiomfolio",
    "format": "pnpm -r --if-present format",
    "clean": "pnpm -r exec rm -rf node_modules .next out dist",
    "generate:pwl-favicon-ico": "node scripts/generate-pwl-favicon-ico.mjs",
    "gh:keyring": "bash scripts/gh-keyring.sh",
    "employees:sync": "tsx scripts/employees-sync.ts",
    "seed:employees": "tsx scripts/seed-employees.ts",
    "seed:epics": "tsx scripts/seed-epic-hierarchy.ts",
    "seed:products": "tsx scripts/seed-products.ts",
    "backfill:transcripts": "tsx scripts/backfill-transcripts.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "js-yaml": "^4.1.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "turbo": "^2.9.8",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  }
}
