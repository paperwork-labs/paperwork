{
  "name": "paperwork",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:filefree": "pnpm --filter @paperwork-labs/filefree dev",
    "dev:launchfree": "pnpm --filter @paperwork-labs/launchfree dev",
    "dev:trinkets": "pnpm --filter @paperwork-labs/trinkets dev",
    "dev:studio": "pnpm --filter @paperwork-labs/studio dev",
    "dev:distill": "pnpm --filter @paperwork-labs/distill dev",
    "build:filefree": "pnpm --filter @paperwork-labs/filefree build",
    "build:launchfree": "pnpm --filter @paperwork-labs/launchfree build",
    "build:trinkets": "pnpm --filter @paperwork-labs/trinkets build",
    "build:studio": "pnpm --filter @paperwork-labs/studio build",
    "build:distill": "pnpm --filter @paperwork-labs/distill build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r exec rm -rf node_modules .next out dist"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  }
}
