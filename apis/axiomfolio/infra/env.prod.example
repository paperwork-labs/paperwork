############################
# Production env (example) #
############################

ENVIRONMENT=production
DEBUG=false
AUTO_MIGRATE_ON_STARTUP=false
LOG_FORMAT=json

SECRET_KEY=change_me_secure
DATABASE_URL=postgresql://user:password@host:5432/axiomfolio
REDIS_URL=redis://:password@host:6379/0
CELERY_BROKER_URL=redis://:password@host:6379/0
CELERY_RESULT_BACKEND=redis://:password@host:6379/0

ENABLE_CELERY_BEAT=false  # DEPRECATED
ENABLE_REDBEAT=false      # DEPRECATED

CORS_ORIGINS=https://axiomfolio.com,https://staging.axiomfolio.com
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STORAGE_URL=redis://:password@host:6379/1

# Provider tier: free | starter | paid | unlimited
MARKET_PROVIDER_POLICY=paid
MARKET_DATA_CACHE_TTL=300

NEW_RELIC_LICENSE_KEY=
