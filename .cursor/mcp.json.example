{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer YOUR_NOTION_API_KEY_HERE\", \"Notion-Version\": \"2025-09-03\"}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "postiz": {
      "command": "npx",
      "args": ["-y", "mcp-postiz-server"],
      "env": {
        "POSTIZ_API_KEY": "YOUR_POSTIZ_API_KEY_HERE",
        "POSTIZ_API_URL": "https://YOUR_POSTIZ_VPS_URL/public/v1"
      }
    }
  }
}
