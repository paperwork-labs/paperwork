{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "slack": {
      "url": "https://mcp.slack.com/mcp",
      "auth": {
        "CLIENT_ID": "3660753192626.8903469228982"
      }
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "postiz": {
      "command": "npx",
      "args": ["-y", "mcp-postiz-server"],
      "env": {
        "POSTIZ_API_KEY": "YOUR_POSTIZ_API_KEY_HERE",
        "POSTIZ_API_URL": "https://YOUR_POSTIZ_VPS_URL/public/v1"
      }
    },
    "gdrive": {
      "url": "http://localhost:3100/mcp",
      "_comment": "Requires scripts/start-gdrive-mcp.sh running. Full read/write: upload, create folders, move, copy, delete."
    },
    "gdrive-readonly": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/path/to/paperwork/infra/gcp/gcp-oauth.keys.json",
        "GDRIVE_CREDENTIALS_PATH": "/path/to/paperwork/infra/gcp/.gdrive-credentials.json"
      },
      "_comment": "Read-only alternative. No write capabilities."
    }
  }
}
