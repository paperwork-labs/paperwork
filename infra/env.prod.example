# FileFree — Production Environment Variables
# Reference only. Production vars are set in Render (API) and Vercel (Web) dashboards.

# === Database (Neon serverless PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?sslmode=require

# === Redis (Upstash serverless) ===
REDIS_URL=rediss://default:token@host:6379

# === Auth ===
SECRET_KEY=<generated-64-char-random-string>
ENCRYPTION_KEY=<generated-fernet-key>

# === OAuth (blank = social login disabled) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Google Cloud ===
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCS_BUCKET_NAME=filefree-uploads-prod

# === Frontend ===
NEXT_PUBLIC_API_URL=https://api.filefree.ai
FRONTEND_URL=https://filefree.ai

# === Environment ===
ENVIRONMENT=production
DEBUG=false
APP_VERSION=0.1.0
