# Paperwork Labs Ops Stack — Hetzner VPS Environment Variables
# Copy to .env: cp env.example .env
# Then fill in all values marked REQUIRED

# === PostgreSQL (shared by n8n + Postiz) ===
POSTGRES_USER=ops
POSTGRES_PASSWORD=           # REQUIRED — generate with: openssl rand -base64 32
POSTGRES_DB=ops

# === Redis ===
REDIS_PASSWORD=              # REQUIRED — generate with: openssl rand -base64 32

# === n8n (workflow automation — agent brain) ===
N8N_USER=admin
N8N_PASSWORD=                # REQUIRED — your n8n dashboard password
N8N_HOST=n8n.paperworklabs.com  # Set to your n8n domain (or server IP for initial setup)

# === n8n Credentials (wired inside n8n UI, listed here for reference) ===
# SLACK_BOT_TOKEN=xoxb-...  # From api.slack.com > Your App > OAuth & Permissions
# GITHUB_PAT=ghp_...        # From github.com/settings/tokens (repo + workflow scopes)
# OPENAI_API_KEY=sk-...     # From platform.openai.com/api-keys

# === Postiz (social media scheduler) ===
POSTIZ_JWT_SECRET=           # REQUIRED — generate with: openssl rand -base64 32
POSTIZ_HOST=social.paperworklabs.com  # Set to your Postiz domain (or server IP for initial setup)
