# Paperwork Labs Ops Stack — Hetzner VPS Environment Variables
# Copy to .env: cp env.example .env
# Then fill in all values marked REQUIRED

# === PostgreSQL (shared by n8n + Postiz) ===
POSTGRES_USER=ops
POSTGRES_PASSWORD=           # REQUIRED — generate with: openssl rand -base64 32
POSTGRES_DB=ops

# === Redis ===
REDIS_PASSWORD=              # REQUIRED — generate with: openssl rand -base64 32

# === n8n (workflow automation) ===
N8N_USER=admin
N8N_PASSWORD=                # REQUIRED — your n8n dashboard password
N8N_HOST=n8n.paperworklabs.com

# === Postiz (social media scheduler) ===
POSTIZ_JWT_SECRET=           # REQUIRED — generate with: openssl rand -base64 32
POSTIZ_HOST=social.paperworklabs.com

# === n8n Credentials (copied into n8n UI; compose does not auto-wire these) ===
# These values are a secure staging area for operators. You must still create
# n8n credentials in the n8n UI (OpenAI + Header Auth creds) and select them on nodes.
OPENAI_API_KEY=              # REQUIRED — From platform.openai.com/api-keys
GITHUB_PAT=                  # REQUIRED — From github.com/settings/tokens (repo scope)

# === Slack Bot (agent workflows) ===
SLACK_BOT_TOKEN=             # REQUIRED — From api.slack.com > Your App > OAuth & Permissions > Bot User OAuth Token
