# Docker Compose development defaults (no secrets)
# Secrets come from .env.secrets via vault sync

# === Database (Docker service hostnames) ===
DATABASE_URL=postgresql+asyncpg://filefree:filefree_dev@postgres:5432/filefree_dev
TEST_DATABASE_URL=postgresql+asyncpg://filefree:filefree_dev@postgres:5432/filefree_test

# === Redis (Docker service) ===
REDIS_URL=redis://redis:6379/0

# === Frontend URLs (local dev) ===
NEXT_PUBLIC_API_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3001

# === Environment ===
ENVIRONMENT=development
DEBUG=true

# === Studio Admin (dev defaults) ===
ADMIN_EMAILS=dev@paperworklabs.com
ADMIN_ACCESS_PASSWORD=dev-local-only
