# FileFree — Development Environment Variables
# Copy to env.dev: cp infra/env.dev.example infra/env.dev

# === Database (Docker service names) ===
DATABASE_URL=postgresql+asyncpg://filefree:filefree_dev@postgres:5432/filefree_dev

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Auth ===
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === OpenAI (blank = mock mode — returns hardcoded W2 data) ===
OPENAI_API_KEY=

# === Google Cloud (blank = mock mode — returns hardcoded OCR output) ===
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=filefree-uploads-dev

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# === Environment ===
ENVIRONMENT=development
DEBUG=true
