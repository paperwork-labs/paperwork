# FileFree — Development Environment Variables
# Copy to env.dev: cp infra/env.dev.example infra/env.dev

# === Database (Docker service names) ===
DATABASE_URL=postgresql+asyncpg://filefree:filefree_dev@postgres:5432/filefree_dev
TEST_DATABASE_URL=postgresql+asyncpg://filefree:filefree_dev@postgres:5432/filefree_test

# === Redis ===
REDIS_URL=redis://redis:6379/0
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=local-dev-token

# === Auth ===
SECRET_KEY=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-generate-with-fernet

# === OAuth (blank = social login disabled in dev) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# === OpenAI (blank = mock mode — returns hardcoded W2 data) ===
OPENAI_API_KEY=

# === Google Cloud (blank = mock mode — returns hardcoded OCR output) ===
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=filefree-uploads-dev

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3001

# === Environment ===
ENVIRONMENT=development
DEBUG=true

# === Ops Dashboard (frontend server-side, set in web/.env.local) ===
# N8N_API_KEY=         # n8n REST API key (generate at n8n.filefree.tax > Settings > API)
# N8N_HOST=https://n8n.filefree.tax
GITHUB_TOKEN=ghp_your_token_here
