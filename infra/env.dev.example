# Local dev env (example; copy to infra/env.dev). Do NOT commit real secrets.
#
# Ports (host side)
DB_HOST_PORT=5432
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8000
WEB_HOST_PORT=3000
FLOWER_HOST_PORT=5555
LADLE_HOST_PORT=61000

# Postgres (container runtime)
POSTGRES_DB=axiomfolio
POSTGRES_USER=axiomfolio
POSTGRES_PASSWORD=change_me_dev

# Redis (container runtime)
REDIS_PASSWORD=change_me_redis

# Backend runtime
APP_NAME=AxiomFolio
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
AUTO_MIGRATE_ON_STARTUP=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STORAGE_URL=
ENABLE_CELERY_BEAT=false  # DEPRECATED — no longer functional, kept for backward compat
ENABLE_REDBEAT=false      # DEPRECATED — no longer functional, kept for backward compat
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360
LOG_FORMAT=text
SECRET_KEY=change-me-in-infra-env-dev
OAUTH_STATE_SECRET=change-me-oauth-state
ENABLE_TRADING=false
SEED_ACCOUNTS_ON_STARTUP=false
# Provider tier: free | starter | paid | unlimited
# All budgets/rates/concurrency derive from this single knob via ProviderPolicy in config.py
MARKET_PROVIDER_POLICY=paid

# Admin seeding (dev convenience; optional)
# Note: Login uses ADMIN_EMAIL (not username). Username is for display only.
ADMIN_SEED_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Market data provider keys (optional but recommended in paid mode)
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
FMP_API_KEY=
POLYGON_API_KEY=

# LLM / Agent API Keys (optional; enables intelligent auto-ops)
OPENAI_API_KEY=
# Agent autonomy level: "full" (auto-execute all), "safe" (auto-execute safe only), "ask" (always ask)
AGENT_AUTONOMY_LEVEL=safe

# Discord Webhooks (optional)
DISCORD_WEBHOOK_SIGNALS=
DISCORD_WEBHOOK_PORTFOLIO_DIGEST=
DISCORD_WEBHOOK_MORNING_BREW=
DISCORD_WEBHOOK_PLAYGROUND=
DISCORD_WEBHOOK_SYSTEM_STATUS=

# Broker integration (optional)
IBKR_HOST=host.docker.internal
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# Tastytrade (optional — OAuth required for SDK v12+)
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_IS_TEST=false
# Legacy (unused in SDK v12+, kept for backward compat)
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_DISCOVER_ON_STARTUP=false

# Schwab (optional)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_AUTH_BASE=https://api.schwab.com/authorize
SCHWAB_CLIENT_ID_SUFFIX=@AMER.OAUTHAP
SCHWAB_REDIRECT_URI=https://api-dev.axiomfolio.com/api/v1/aggregator/schwab/callback
SCHWAB_ACCOUNTS=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Apple Sign-In (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# Email verification (optional)
RESEND_API_KEY=

# Observability (optional)
NEW_RELIC_LICENSE_KEY=

# Cloudflare tunnel (optional)
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_TUNNEL_ID=
CLOUDFLARED_CONNECTOR_ID=

# Rate limiting / caching (optional)
MARKET_DATA_CACHE_TTL=300

# Trading/scanner knobs (optional; some may be ignored if not modeled)
DEFAULT_ATR_PERIOD=14
DEFAULT_POSITION_SIZE_PCT=2.0
MAX_DAILY_TRADES=10
MAX_PORTFOLIO_RISK=20.0
MAX_SCANNER_TICKERS=500
SCANNER_SCHEDULE_MINUTE=0
SCANNER_SCHEDULE_HOUR=9,15
ATR_ENTRY_MAX_DISTANCE=4.0
ATR_SCALE_OUT_LEVELS=[7.0,8.0,9.0,10.0]
ATR_STOP_LOSS_MULTIPLIER=1.5

