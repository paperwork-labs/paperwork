#!/bin/sh
#
# Pre-push hook: prevents direct pushes to main/master.
# Override for emergencies: ALLOW_PUSH_TO_MAIN=1 git push
#
# Install: make setup-hooks
#   or:    ln -sf ../../infra/git-hooks/pre-push .git/hooks/pre-push

if [ "$ALLOW_PUSH_TO_MAIN" = "1" ]; then
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE "refs/heads/(main|master)$"; then
    echo ""
    echo "  BLOCKED: Direct push to $(echo "$remote_ref" | sed 's|refs/heads/||') is not allowed."
    echo ""
    echo "  Create a feature branch and open a PR instead:"
    echo "    git checkout -b feat/my-feature"
    echo "    git push -u origin HEAD"
    echo "    gh pr create"
    echo ""
    echo "  Emergency override: ALLOW_PUSH_TO_MAIN=1 git push"
    echo ""
    exit 1
  fi
done

exit 0
