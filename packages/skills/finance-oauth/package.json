{
  "name": "@paperwork/skills-finance-oauth",
  "version": "0.0.1",
  "description": "Provider-agnostic brokerage & financial OAuth scaffold (PKCE helpers + BrokerageAdapter).",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
