{
  "name": "@paperwork-labs/skill-gmail",
  "version": "0.1.0",
  "description": "Gmail integration skill for Paperwork Labs: OAuth authentication, message retrieval, attachment extraction, and label management via googleapis.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./attachments": "./src/attachments.ts",
    "./labels": "./src/labels.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "googleapis": "^148.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
