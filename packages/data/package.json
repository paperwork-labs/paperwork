{
  "name": "@paperwork-labs/data",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./schemas/*": "./src/schemas/*.ts",
    "./engine/*": "./src/engine/*.ts",
    "./types/*": "./src/types/*.ts",
    "./portals/*": "./src/portals/*.json",
    "./portals/fees": "./src/portals/fees.ts"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "build": "pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.scripts.json",
    "type-check": "pnpm run typecheck",
    "parse:tax": "tsx scripts/parse-tax-foundation.ts",
    "parse:formation": "tsx scripts/parse-formation-rules.ts",
    "review": "tsx scripts/review.ts",
    "review:approve": "tsx scripts/review.ts --approve"
  }
}
